{
  "name": "@calumk/editorjs-columns",
  "version": "0.3.2",
  "description": "Columns, for EditorJS",
  "main": "./dist/editorjs-columns.umd.js",
  "module": "./dist/editorjs-columns.mjs",
  "exports": {
    ".": {
      "import": "./dist/editorjs-columns.mjs",
      "require": "./dist/editorjs-columns.umd.js"
    }
  },
  "scripts": {
    "dev": "vite",
    "build": "vite build",
