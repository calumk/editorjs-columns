    "lint:fix": "eslint src/**/*.js --fix",
    "format": "prettier --write src/**/*.{js,scss}",
    "format:check": "prettier --check src/**/*.{js,scss}"
  },
  "author": "Calum Knott",
  "license": "MIT",
  "dependencies": {
    "@editorjs/editorjs": "^2.30.8",
    "uuid": "^8.3.2"
  },
  "devDependencies": {
    "eslint": "^8.57.0",
    "prettier": "^3.3.3",
    "sass": "^1.55.0",
    "vite": "^5.4.19",
    "vite-plugin-css-injected-by-js": "^3.5.1"
  }
